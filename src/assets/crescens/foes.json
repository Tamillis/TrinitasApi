    "abilities": [
        {
            "name": "Backstab",
            "description": "Deals +2 damage ranks when attacking a target that is unaware or engaged with another combatant."
        },
        {
            "name": "Commanding",
            "description": "Adjacent allies gain an Advantage on attacks."
        },
        {
            "name": "Patch Up",
            "description": "As a Bonus Action, remove 1 Injury Rank from an adjacent ally."
        },
        {
            "name": "Spellshield",
            "description": "May use Intelligence for Evasion instead of Agility."
        },
        {
            "name": "Volley",
            "description": "May attack two targets in the same round as one Action, splitting the attack between both at one Disadvantage each."
        },
        {
            "name": "Pack Hunter",
            "description": "When two or more Wolves attack the same target in a round, each gains an Advantage."
        },
        {
            "name": "Grapple",
            "description": "On a hit, may immediately attempt a Grapple as a Bonus Action using Strength d10."
        },
        {
            "name": "Web",
            "description": "As an Action, may attempt to Immobilise a target in Short range. Target rolls Agility vs TN 6 or becomes Immobilised until they break free."
        },
        {
            "name": "Venomous",
            "description": "On a hit, the target must roll Strength vs TN 6 or gain a Poison Injury of rank 2 at the end of the round."
        },
        {
            "name": "Frightful Presence",
            "description": "Any character who takes damage from this creature must roll Spirit vs TN 6 or gain the Frightened condition until the end of their next round."
        },
        {
            "name": "Breath Weapon",
            "description": "Once per fight, may breathe fire in a cone hitting all targets in Short range. Each target rolls Agility vs TN 8 or takes d8 Fire damage."
        },
        {
            "name": "Regeneration",
            "description": "At the end of each round, reduces its highest Injury rank by 1. Fire and Acid damage cannot be regenerated."
        },
        {
            "name": "Hulking",
            "description": "May target two adjacent enemies with a single Attack Action."
        },
        {
            "name": "Threat Assessment",
            "description": "Attacks ignore 1 point of Evasion against targets already hit this fight."
        },
        {
            "name": "Immune to Psychic",
            "description": "Cannot be affected by mind-altering abilities or conditions."
        },
        {
            "name": "Chameleonic",
            "description": "Is Hidden at the start of combat and whenever it moves without attacking."
        },
        {
            "name": "Acid Blood",
            "description": "Any character who deals a melee hit to this creature takes d4 Acid damage."
        },
        {
            "name": "Shield Wall",
            "description": "When adjacent to another Legionary, both gain +1 Armour and an Advantage on Defend actions."
        },
        {
            "name": "Throw Pilum",
            "description": "Once per fight, may throw their pilum at a target in Short range as a Bonus Action."
        },
        {
            "name": "Mounted",
            "description": "The Unstable condition is removed when fighting from horseback, and gains +1 damage when charging."
        },
        {
            "name": "Iaijutsu",
            "description": "Once per fight, may make a surprise attack at the start of combat before any other actions are declared, dealing +2 damage ranks."
        },
        {
            "name": "Deflect",
            "description": "May use Agility for their Defend action, deflecting attacks with their blade."
        },
        {
            "name": "Mesmerise",
            "description": "As an Action, targets one character in Short range. That character rolls Spirit vs TN 8 or gains the Charmed condition until they take damage."
        },
        {
            "name": "Mist Form",
            "description": "Once per fight, may become incorporeal as a Bonus Action, avoiding one attack entirely."
        },
        {
            "name": "Sunlight Vulnerability",
            "description": "In direct sunlight, has a Disadvantage on all rolls and cannot use Mist Form."
        },
        {
            "name": "Silver Weakness",
            "description": "Silver weapons deal +2 damage ranks and bypass natural armour."
        },
        {
            "name": "Feral Rage",
            "description": "When this creature takes damage of rank 3 or higher, it immediately makes a free attack against the attacker."
        },
        {
            "name": "Infectious Bite",
            "description": "A character reduced to their Limit by this creature's bite must make a Spirit roll vs TN 8 at next Rest or begin an unwanted transformation. GM's discretion on consequences."
        },
        {
            "name": "Divine Radiance",
            "description": "Once per fight as an Action, may blind all enemies in Short range. Targets roll Spirit vs TN 10 or gain the Blinded condition for one round."
        },
        {
            "name": "Celestial",
            "description": "Immune to Poison and Psychic damage."
        },
        {
            "name": "Terrifying Form",
            "description": "Any character who begins their first round in combat with this creature must roll Spirit vs TN 8 or gain the Frightened condition."
        },
        {
            "name": "Unholy Resilience",
            "description": "Reduces all incoming damage by 1 to a minimum of 1, except from holy or silver sources."
        },
        {
            "name": "Silver Tongue",
            "description": "May use Deception or Persuasion as an attack, dealing Psychic damage on a failed Spirit roll vs TN equal to its skill rank + 4."
        },
        {
            "name": "Binding Contract",
            "description": "Once per fight, may offer a target a bargain. If accepted, the target gains a temporary benefit but suffers a Rank 3 Psychic Injury at the start of each subsequent fight until the contract is fulfilled."
        }
    ]
}